# 코어 번호는 본인 머신에 맞게 수정 (lscpu, nproc 참고)
# 사용법:
#   cp cpu_affinity.env.example cpu_affinity.env
#   편집 후:
#     set -a && source /path/to/mavros/chmy/scripts/cpu_affinity.env && set +a
#     python3 .../chmy/test/0_run_multi_topic.py ...
#     python3 .../chmy/test/5_end_to_end_measurement.py ...

# --- 이 저장소 테스트 스크립트가 읽는 변수 ---
CHMY_CPU_MAVROS=0,1
CHMY_CPU_TOPIC_NODES=2,3,4,5
CHMY_CPU_MAIN=6,7
# system_monitor.py (비우면 TOPIC과 동일 코어)
# CHMY_CPU_MONITOR=2,3,4,5

# --- 아래는 수동 실행 예시 (스크립트가 자동으로 안 씀) ---
# PX4 SITL (빌드/런치 방식에 맞게 한 줄로):
#   taskset -c 0,1 <px4_sitl_명령>
#
# QGroundControl:
#   taskset -c 8,9 ./QGroundControl*.AppImage
#
# Cursor (Electron 자식까지 완전 분리는 어렵고, 시작 프로세스 기준으로 묶음):
#   taskset -c 10,11,12,13 cursor
#   또는 데스크톱 단축아이콘 Exec 앞에 taskset -c ... 추가
